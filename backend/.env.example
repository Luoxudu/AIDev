# ══════════════════════════════════════════════════════════════
#  LLM 大模型配置（必须）
# ══════════════════════════════════════════════════════════════
LLM_MODEL=deepseek-v4-flash
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://your-api-endpoint/v1

# ══════════════════════════════════════════════════════════════
#  本地 Embedding 配置（通过 Ollama）
# ══════════════════════════════════════════════════════════════
EMBEDDING_MODEL=qwen3-embed:0.6b-q8_0-ctx512
OLLAMA_BASE_URL=http://localhost:11434

# ══════════════════════════════════════════════════════════════
#  存储路径
# ══════════════════════════════════════════════════════════════
PERSIST_DIR=./data/db/chroma_db
CHAT_HISTORY_DB=./data/db/chat_history.db
CHAT_HISTORY_WEB_DB=./data/db/chat_history_web.db
BM25_INDEX_PATH=./data/db/bm25_index.pkl

# ══════════════════════════════════════════════════════════════
#  记忆系统
# ══════════════════════════════════════════════════════════════
MEMORY_ENABLED=true
MEMORY_AUTO_EXTRACT=true
MEMORY_PROFILE_PATH=./data/memory/profile.json

# ══════════════════════════════════════════════════════════════
#  对话历史
# ══════════════════════════════════════════════════════════════
CHAT_HISTORY_WINDOW=10

# ══════════════════════════════════════════════════════════════
#  分块配置
# ══════════════════════════════════════════════════════════════
CHUNK_METHOD=semantic
SEMANTIC_CHUNK_PERCENTILE=80
CHUNK_SIZE=300
CHUNK_OVERLAP=80
PARENT_CHUNK_SIZE=4
PARENT_CHUNK_OVERLAP=1

# ══════════════════════════════════════════════════════════════
#  检索增强配置
# ══════════════════════════════════════════════════════════════
RETRIEVER_K=4
RETRIEVER_SCORE_THRESHOLD=0.15
MULTI_QUERY_COUNT=3
HYDE_ENABLED=true
HYDE_MIN_QUERY_LENGTH=10

# ══════════════════════════════════════════════════════════════
#  混合检索 + 精排
# ══════════════════════════════════════════════════════════════
RETRIEVER_HYBRID_K=10
RETRIEVER_HYBRID_ALPHA=0.3
RETRIEVER_CROSSENCODER_TOP_K=5
RETRIEVER_MERGE_TOP_K=15

# Reranker 精排模型
# 启用后若本地不存在模型会自动从 ModelScope 下载到此目录
# 关闭后跳过精排，不需要模型
RERANKER_ENABLED=true
RERANKER_MODEL_PATH=D:\Hugging_Face\models\Qwen3-Reranker-0.6B
